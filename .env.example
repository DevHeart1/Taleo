# Copy to .env.local for development. On Vercel, set the same keys for Production
# (and Preview if you use it), then redeploy — NEXT_PUBLIC_* is inlined at build time.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (optional; used for privileged storage/API routes)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Google Gemini API key (required for story text and image generations)
GEMINI_API_KEY=

# Optional: routes the Disney/Pixar image style through Nano Banana
# (Gemini 2.5 Flash Image) via Vercel AI Gateway — ~4× cheaper than
# gpt-image-1 high, zero markup over Google's list price, and every Vercel
# team gets $5/month of free Gateway credit. Create a key at
# https://vercel.com/dashboard/ai-gateway/api-keys. If unset (and no
# VERCEL_OIDC_TOKEN from `vercel env pull`), Pixar illustration fails unless you
# enable the OpenAI fallback below.
AI_GATEWAY_API_KEY=

# Optional: allow OpenAI `gpt-image-1` as Pixar backup when Gemini fails.
# Default off — Pixar uses AI Gateway only unless you set `true`.
OPENAI_PIXAR_FALLBACK_ENABLED=
